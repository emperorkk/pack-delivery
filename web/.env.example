# Same-origin proxy prefix. The Worker hosts both the PWA and `/api/*`,
# so a relative URL keeps requests CORS-free in production. Override only
# if a different host (e.g. Pages) consumes a remote Worker proxy.
VITE_SOFT1_PROXY=/api

# Public URL where the CST installer file is hosted (shown in the
# "CST missing" dialog). Drop the .CST file in `web/public/` to serve
# it from the same Worker.
VITE_CST_DOWNLOAD_URL=/aicmp.pack-delivery.CST
